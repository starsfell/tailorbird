#!/bin/bash
# tailorbird.app 启动器:exec 进 scripts/start_prod.sh。
# 启动器进程跑完 start_prod.sh 后立即退出(uvicorn detach 到后台),
# 这样 macOS 不会把 .app 标记为运行中,图标能反复触发打开浏览器。
# 退出后端:scripts/quit_prod.sh。日志:/tmp/tailorbird.log。
# 注:ROOT 写死成项目路径,这样 .app 可以放在 /Applications。
ROOT="/Users/starsfell/SOL/CANOPUS/birdye"
exec "$ROOT/scripts/start_prod.sh"
